// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  DEALAK Real Estate Application — Database Schema (Production-Ready)   ║
// ║  Engine:   PostgreSQL 16+ with PostGIS Extension                       ║
// ║  Currency: SYP (Syrian Pound) — Default                                ║
// ║  Charset:  UTF-8 (Arabic + English support)                            ║
// ║  Version:  2.0.0                                                       ║
// ║  Date:     11 April 2026                                               ║
// ╚══════════════════════════════════════════════════════════════════════════╝

// ──────────────────────────────────────────────────────────────────────────
// 1. USERS — المستخدمون
// ──────────────────────────────────────────────────────────────────────────
Table users {
  id            bigint    [pk, increment]
  email         varchar(255) [unique, not null]
  phone         varchar(20)  [unique]
  password_hash varchar(255) [not null]
  first_name    varchar(100) [not null]
  last_name     varchar(100) [not null]
  role          enum('admin', 'agent', 'buyer', 'seller', 'tenant', 'landlord') [default: 'buyer', not null]
  avatar_url    varchar(500)
  bio           text
  national_id   varchar(30)  [unique, note: 'رقم الهوية الوطنية — اختياري للتحقق']
  is_verified   boolean   [default: false]
  is_active     boolean   [default: true]
  last_login_at timestamp
  deleted_at    timestamp [note: 'Soft-delete timestamp — NULL يعني نشط']
  created_at    timestamp [default: `now()`, not null]
  updated_at    timestamp [default: `now()`, not null]

  indexes {
    email              [unique]
    phone              [unique]
    (first_name, last_name) [name: 'idx_users_full_name']
    role               [name: 'idx_users_role']
    is_active          [name: 'idx_users_active']
    last_login_at      [name: 'idx_users_last_login']
    created_at         [name: 'idx_users_created']
    (role, is_active)  [name: 'idx_users_role_active', note: 'Composite: filter active users by role']
    deleted_at         [name: 'idx_users_soft_delete', note: 'Partial index WHERE deleted_at IS NULL']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 2. USER_DEVICES — أجهزة المستخدمين (Push Notifications)
// ──────────────────────────────────────────────────────────────────────────
Table user_devices {
  id           bigint    [pk, increment]
  user_id      bigint    [not null, ref: > users.id]
  device_token varchar(500) [not null]
  platform     enum('ios', 'android', 'web') [not null]
  device_info  json      [note: 'معلومات الجهاز: model, OS version, etc.']
  is_active    boolean   [default: true]
  last_used_at timestamp
  created_at   timestamp [default: `now()`, not null]

  indexes {
    user_id    [name: 'idx_devices_user']
    (device_token, platform) [unique, name: 'uq_device_token_platform']
    is_active  [name: 'idx_devices_active']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 3. REFRESH_TOKENS — رموز التحديث (JWT Auth)
// ──────────────────────────────────────────────────────────────────────────
Table refresh_tokens {
  id              bigint    [pk, increment]
  user_id         bigint    [not null, ref: > users.id]
  token_hash      varchar(255) [not null, unique]
  device_id       bigint    [ref: > user_devices.id]
  ip_address      varchar(45) [note: 'IPv4/IPv6']
  user_agent      varchar(500)
  expires_at      timestamp [not null]
  revoked_at      timestamp
  created_at      timestamp [default: `now()`, not null]

  indexes {
    user_id        [name: 'idx_refresh_user']
    token_hash     [unique, name: 'uq_refresh_token']
    expires_at     [name: 'idx_refresh_expires']
    (user_id, revoked_at) [name: 'idx_refresh_user_active', note: 'Active tokens: WHERE revoked_at IS NULL']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 4. PROPERTIES — العقارات
// ──────────────────────────────────────────────────────────────────────────
Table properties {
  id            bigint    [pk, increment]
  owner_id      bigint    [not null, ref: > users.id]
  agent_id      bigint    [ref: > users.id, note: 'الوسيط العقاري — اختياري']
  title         varchar(255) [not null]
  slug          varchar(300) [unique, not null, note: 'SEO-friendly URL slug']
  description   text      [not null]
  property_type enum('apartment', 'house', 'villa', 'land', 'commercial', 'office', 'warehouse', 'chalet', 'farm') [not null]
  status        enum('available', 'sold', 'rented', 'pending', 'off_market', 'under_review') [default: 'under_review', not null]
  listing_type  enum('sale', 'rent', 'daily_rent') [not null]
  price         decimal(15, 2) [not null, note: 'CHECK(price > 0)']
  currency      varchar(3)    [default: 'SYP', not null]
  area_sqm      decimal(10, 2) [not null, note: 'CHECK(area_sqm > 0)']
  bedrooms      smallint  [note: 'CHECK(bedrooms >= 0)']
  bathrooms     smallint  [note: 'CHECK(bathrooms >= 0)']
  floors        smallint  [default: 1, note: 'CHECK(floors >= 1)']
  floor_number  smallint  [note: 'رقم الطابق — للشقق']
  year_built    smallint  [note: 'CHECK(year_built >= 1900)']
  furnishing    enum('furnished', 'semi_furnished', 'unfurnished') [default: 'unfurnished']
  direction     enum('north', 'south', 'east', 'west', 'northeast', 'northwest', 'southeast', 'southwest')
  address       varchar(500)  [not null]
  city          varchar(100)  [not null]
  district      varchar(100)
  latitude      decimal(10, 8)
  longitude     decimal(11, 8)
  // PostGIS: يُستخدم GEOMETRY(Point, 4326) في SQL الفعلي مع GiST Index
  is_featured   boolean   [default: false]
  is_negotiable boolean   [default: true]
  view_count    int       [default: 0, note: 'CHECK(view_count >= 0)']
  deleted_at    timestamp [note: 'Soft-delete']
  published_at  timestamp [note: 'تاريخ النشر الفعلي بعد الموافقة']
  created_at    timestamp [default: `now()`, not null]
  updated_at    timestamp [default: `now()`, not null]

  indexes {
    slug               [unique, name: 'uq_property_slug']
    owner_id           [name: 'idx_prop_owner']
    agent_id           [name: 'idx_prop_agent']
    property_type      [name: 'idx_prop_type']
    status             [name: 'idx_prop_status']
    listing_type       [name: 'idx_prop_listing']
    price              [name: 'idx_prop_price']
    city               [name: 'idx_prop_city']
    district           [name: 'idx_prop_district']
    (latitude, longitude) [name: 'idx_prop_coords']
    is_featured        [name: 'idx_prop_featured']
    created_at         [name: 'idx_prop_created']
    published_at       [name: 'idx_prop_published']
    deleted_at         [name: 'idx_prop_soft_delete']

    // Composite indexes for common queries
    (city, property_type, status)          [name: 'idx_prop_city_type_status']
    (listing_type, status, price)          [name: 'idx_prop_listing_status_price']
    (city, listing_type, property_type, price) [name: 'idx_prop_search_combo']
    (status, is_featured, created_at)      [name: 'idx_prop_featured_latest']

    // Full-text search — في SQL: GIN(to_tsvector('arabic', title || ' ' || description))
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 5. PROPERTY_FEATURES — ميزات العقار (Many-to-Many ← أفضل من JSONB)
// ──────────────────────────────────────────────────────────────────────────
Table property_features {
  id          bigint    [pk, increment]
  property_id bigint    [not null, ref: > properties.id]
  feature_key varchar(100) [not null, note: 'مثال: parking, pool, elevator, garden, security, balcony']
  feature_value varchar(255) [note: 'قيمة اختيارية: 2 (عدد مواقف), true, etc.']
  created_at  timestamp [default: `now()`, not null]

  indexes {
    property_id [name: 'idx_feat_property']
    feature_key [name: 'idx_feat_key']
    (property_id, feature_key) [unique, name: 'uq_property_feature']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 6. PROPERTY_IMAGES — صور العقار
// ──────────────────────────────────────────────────────────────────────────
Table property_images {
  id          bigint    [pk, increment]
  property_id bigint    [not null, ref: > properties.id]
  image_url   varchar(500) [not null]
  thumbnail_url varchar(500) [note: 'صورة مصغرة مُعالجة']
  caption     varchar(255)
  mime_type   varchar(50)  [note: 'image/jpeg, image/webp, etc.']
  file_size   int       [note: 'الحجم بالبايت']
  width       smallint
  height      smallint
  is_primary  boolean   [default: false]
  sort_order  smallint  [default: 0, note: 'CHECK(sort_order >= 0)']
  created_at  timestamp [default: `now()`, not null]

  indexes {
    property_id [name: 'idx_img_property']
    is_primary  [name: 'idx_img_primary']
    sort_order  [name: 'idx_img_order']
    (property_id, is_primary) [name: 'idx_img_prop_primary']
    (property_id, sort_order) [name: 'idx_img_prop_order']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 7. FAVORITES — المفضلة
// ──────────────────────────────────────────────────────────────────────────
Table favorites {
  id          bigint    [pk, increment]
  user_id     bigint    [not null, ref: > users.id]
  property_id bigint    [not null, ref: > properties.id]
  created_at  timestamp [default: `now()`, not null]

  indexes {
    (user_id, property_id) [unique, name: 'uq_user_favorite']
    user_id     [name: 'idx_fav_user']
    property_id [name: 'idx_fav_property']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 8. SAVED_SEARCHES — البحوث المحفوظة
// ──────────────────────────────────────────────────────────────────────────
Table saved_searches {
  id            bigint    [pk, increment]
  user_id       bigint    [not null, ref: > users.id]
  name          varchar(100) [not null]
  filters       json      [not null, note: 'JSON: {city, type, min_price, max_price, bedrooms, ...}']
  notify_on_match boolean [default: true, note: 'تنبيه عند ظهور عقار مطابق']
  last_notified_at timestamp
  created_at    timestamp [default: `now()`, not null]
  updated_at    timestamp [default: `now()`, not null]

  indexes {
    user_id [name: 'idx_saved_search_user']
    (user_id, notify_on_match) [name: 'idx_saved_search_notify']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 9. REQUESTS — الطلبات العقارية
// ──────────────────────────────────────────────────────────────────────────
Table requests {
  id              bigint    [pk, increment]
  user_id         bigint    [not null, ref: > users.id]
  property_id     bigint    [ref: > properties.id, note: 'طلب على عقار محدد — اختياري']
  request_type    enum('buy', 'rent', 'sell', 'valuation', 'visit') [not null]
  property_type   enum('apartment', 'house', 'villa', 'land', 'commercial', 'office', 'warehouse', 'chalet', 'farm')
  min_price       decimal(15, 2) [note: 'CHECK(min_price >= 0)']
  max_price       decimal(15, 2) [note: 'CHECK(max_price >= min_price)']
  currency        varchar(3)  [default: 'SYP']
  min_area_sqm    decimal(10, 2) [note: 'CHECK(min_area_sqm >= 0)']
  max_area_sqm    decimal(10, 2) [note: 'CHECK(max_area_sqm >= min_area_sqm)']
  bedrooms        smallint [note: 'CHECK(bedrooms >= 0)']
  bathrooms       smallint [note: 'CHECK(bathrooms >= 0)']
  preferred_city  varchar(100)
  preferred_district varchar(100)
  description     text
  urgency         enum('low', 'medium', 'high') [default: 'medium']
  status          enum('open', 'in_progress', 'matched', 'closed', 'cancelled') [default: 'open', not null]
  assigned_agent_id bigint [ref: > users.id, note: 'الوسيط المُعيّن — اختياري']
  closed_at       timestamp
  created_at      timestamp [default: `now()`, not null]
  updated_at      timestamp [default: `now()`, not null]

  indexes {
    user_id          [name: 'idx_req_user']
    property_id      [name: 'idx_req_property']
    request_type     [name: 'idx_req_type']
    status           [name: 'idx_req_status']
    preferred_city   [name: 'idx_req_city']
    urgency          [name: 'idx_req_urgency']
    assigned_agent_id [name: 'idx_req_agent']
    created_at       [name: 'idx_req_created']
    (user_id, status)      [name: 'idx_req_user_status']
    (status, urgency)      [name: 'idx_req_status_urgency']
    (min_price, max_price) [name: 'idx_req_price_range']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 10. DEALS — الصفقات
// ──────────────────────────────────────────────────────────────────────────
Table deals {
  id             bigint    [pk, increment]
  property_id    bigint    [not null, ref: > properties.id]
  buyer_id       bigint    [not null, ref: > users.id]
  seller_id      bigint    [not null, ref: > users.id]
  agent_id       bigint    [ref: > users.id]
  request_id     bigint    [ref: > requests.id]
  deal_type      enum('sale', 'rent') [not null]
  agreed_price   decimal(15, 2) [not null, note: 'CHECK(agreed_price > 0)']
  currency       varchar(3) [default: 'SYP', not null]
  commission_rate decimal(5, 2) [default: 2.50, note: 'CHECK(commission_rate >= 0 AND commission_rate <= 100)']
  commission_amount decimal(15, 2) [note: 'CHECK(commission_amount >= 0)']
  deposit_amount decimal(15, 2) [note: 'CHECK(deposit_amount >= 0)']
  deposit_paid   boolean   [default: false]

  // حقول الإيجار
  rent_start_date date    [note: 'تاريخ بداية الإيجار']
  rent_end_date   date    [note: 'تاريخ نهاية الإيجار — CHECK(end >= start)']
  rent_period     enum('monthly', 'quarterly', 'semi_annual', 'annual') [note: 'فترة الإيجار']

  signed_at      timestamp
  contract_url   varchar(500) [note: 'رابط العقد الموقّع']
  status         enum('negotiating', 'pending_deposit', 'deposit_paid', 'contract_signed', 'completed', 'cancelled', 'disputed') [default: 'negotiating', not null]
  cancellation_reason text
  notes          text
  deleted_at     timestamp [note: 'Soft-delete']
  created_at     timestamp [default: `now()`, not null]
  updated_at     timestamp [default: `now()`, not null]

  indexes {
    property_id     [name: 'idx_deal_property']
    buyer_id        [name: 'idx_deal_buyer']
    seller_id       [name: 'idx_deal_seller']
    agent_id        [name: 'idx_deal_agent']
    request_id      [name: 'idx_deal_request']
    status          [name: 'idx_deal_status']
    deal_type       [name: 'idx_deal_type']
    created_at      [name: 'idx_deal_created']
    signed_at       [name: 'idx_deal_signed']
    (buyer_id, status)   [name: 'idx_deal_buyer_status']
    (seller_id, status)  [name: 'idx_deal_seller_status']
    (agent_id, status)   [name: 'idx_deal_agent_status']
    (deal_type, status, created_at) [name: 'idx_deal_type_status_date']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 11. PAYMENTS — الدفعات المالية
// ──────────────────────────────────────────────────────────────────────────
Table payments {
  id                    bigint    [pk, increment]
  deal_id               bigint    [not null, ref: > deals.id]
  payer_id              bigint    [not null, ref: > users.id]
  payee_id              bigint    [not null, ref: > users.id]
  payment_type          enum('deposit', 'installment', 'full_payment', 'commission', 'refund', 'rent_payment') [not null]
  amount                decimal(15, 2) [not null, note: 'CHECK(amount > 0)']
  currency              varchar(3)  [default: 'SYP', not null]
  payment_method        enum('cash', 'bank_transfer', 'check', 'mobile_money', 'credit_card', 'e_wallet') [not null]
  transaction_reference varchar(100) [unique]
  receipt_url           varchar(500) [note: 'رابط إيصال الدفع']
  installment_number    smallint  [note: 'رقم القسط — للتقسيط']
  total_installments    smallint  [note: 'إجمالي عدد الأقساط']
  status                enum('pending', 'processing', 'completed', 'failed', 'refunded', 'partially_refunded') [default: 'pending', not null]
  paid_at               timestamp
  notes                 text
  created_at            timestamp [default: `now()`, not null]
  updated_at            timestamp [default: `now()`, not null]

  indexes {
    deal_id     [name: 'idx_pay_deal']
    payer_id    [name: 'idx_pay_payer']
    payee_id    [name: 'idx_pay_payee']
    status      [name: 'idx_pay_status']
    payment_type [name: 'idx_pay_type']
    paid_at     [name: 'idx_pay_paid_at']
    created_at  [name: 'idx_pay_created']
    transaction_reference [unique, name: 'uq_pay_txn_ref']
    (deal_id, status)        [name: 'idx_pay_deal_status']
    (deal_id, payment_type)  [name: 'idx_pay_deal_type']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 12. DISCOUNTS — الخصومات وكوبونات الخصم
// ──────────────────────────────────────────────────────────────────────────
Table discounts {
  id                  bigint    [pk, increment]
  property_id         bigint    [ref: > properties.id, note: 'خصم على عقار محدد — اختياري']
  code                varchar(50) [unique, note: 'كود الخصم']
  name                varchar(100) [not null]
  discount_type       enum('percentage', 'fixed_amount') [not null]
  discount_value      decimal(15, 2) [not null, note: 'CHECK(discount_value > 0)']
  currency            varchar(3)  [default: 'SYP']
  min_property_value  decimal(15, 2) [note: 'CHECK(min_property_value >= 0)']
  max_discount_amount decimal(15, 2) [note: 'CHECK(max_discount_amount >= 0)']
  usage_limit         int       [default: 1, note: 'CHECK(usage_limit > 0)']
  usage_count         int       [default: 0, note: 'CHECK(usage_count >= 0)']
  valid_from          timestamp [not null]
  valid_until         timestamp [not null, note: 'CHECK(valid_until > valid_from)']
  is_active           boolean   [default: true]
  created_by          bigint    [not null, ref: > users.id]
  created_at          timestamp [default: `now()`, not null]
  updated_at          timestamp [default: `now()`, not null]

  indexes {
    property_id    [name: 'idx_disc_property']
    code           [unique, name: 'uq_disc_code']
    is_active      [name: 'idx_disc_active']
    created_by     [name: 'idx_disc_creator']
    valid_from     [name: 'idx_disc_valid_from']
    valid_until    [name: 'idx_disc_valid_until']
    (code, is_active)          [name: 'idx_disc_code_active']
    (is_active, valid_from, valid_until) [name: 'idx_disc_active_period']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 13. CONVERSATIONS — المحادثات (Thread-based)
// ──────────────────────────────────────────────────────────────────────────
Table conversations {
  id            bigint    [pk, increment]
  property_id   bigint    [ref: > properties.id, note: 'المحادثة حول عقار معين']
  participant_1 bigint    [not null, ref: > users.id]
  participant_2 bigint    [not null, ref: > users.id]
  last_message_at timestamp
  is_archived_1 boolean   [default: false, note: 'مؤرشفة من المشارك الأول']
  is_archived_2 boolean   [default: false, note: 'مؤرشفة من المشارك الثاني']
  created_at    timestamp [default: `now()`, not null]
  updated_at    timestamp [default: `now()`, not null]

  indexes {
    property_id    [name: 'idx_conv_property']
    participant_1  [name: 'idx_conv_p1']
    participant_2  [name: 'idx_conv_p2']
    last_message_at [name: 'idx_conv_last_msg']
    (participant_1, participant_2, property_id) [unique, name: 'uq_conv_participants_property']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 14. MESSAGES — الرسائل
// ──────────────────────────────────────────────────────────────────────────
Table messages {
  id                bigint    [pk, increment]
  conversation_id   bigint    [not null, ref: > conversations.id]
  sender_id         bigint    [not null, ref: > users.id]
  content           text      [not null]
  message_type      enum('text', 'image', 'file', 'location', 'voice') [default: 'text', not null]
  attachments       json      [note: 'JSON array of attachment URLs']
  is_read           boolean   [default: false]
  read_at           timestamp
  is_deleted        boolean   [default: false]
  created_at        timestamp [default: `now()`, not null]

  indexes {
    conversation_id  [name: 'idx_msg_conversation']
    sender_id        [name: 'idx_msg_sender']
    is_read          [name: 'idx_msg_read']
    created_at       [name: 'idx_msg_created']
    (conversation_id, created_at)  [name: 'idx_msg_conv_time']
    (conversation_id, is_read)     [name: 'idx_msg_conv_unread']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 15. NOTIFICATIONS — الإشعارات
// ──────────────────────────────────────────────────────────────────────────
Table notifications {
  id                    bigint    [pk, increment]
  user_id               bigint    [not null, ref: > users.id]
  notification_type     enum('message', 'deal_update', 'payment_received', 'property_inquiry', 'price_drop', 'new_listing', 'request_update', 'review', 'system') [not null]
  title                 varchar(255) [not null]
  content               text
  related_entity_type   enum('property', 'deal', 'payment', 'request', 'message', 'conversation', 'review')
  related_entity_id     bigint
  action_url            varchar(500) [note: 'رابط مباشر للإشعار']
  is_read               boolean   [default: false]
  read_at               timestamp
  is_push_sent          boolean   [default: false, note: 'تم إرسال Push Notification']
  created_at            timestamp [default: `now()`, not null]

  indexes {
    user_id              [name: 'idx_notif_user']
    notification_type    [name: 'idx_notif_type']
    is_read              [name: 'idx_notif_read']
    created_at           [name: 'idx_notif_created']
    (user_id, is_read)   [name: 'idx_notif_user_unread']
    (related_entity_type, related_entity_id) [name: 'idx_notif_entity']
    (user_id, created_at) [name: 'idx_notif_user_timeline']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 16. REVIEWS — التقييمات والمراجعات
// ──────────────────────────────────────────────────────────────────────────
Table reviews {
  id            bigint    [pk, increment]
  reviewer_id   bigint    [not null, ref: > users.id]
  reviewed_user_id bigint [ref: > users.id, note: 'تقييم مستخدم — اختياري']
  property_id   bigint    [ref: > properties.id, note: 'تقييم عقار — اختياري']
  deal_id       bigint    [ref: > deals.id, note: 'مرتبط بصفقة مكتملة']
  rating        smallint  [not null, note: 'CHECK(rating >= 1 AND rating <= 5)']
  title         varchar(200)
  comment       text
  is_visible    boolean   [default: true]
  response      text      [note: 'رد المالك أو الوسيط']
  response_at   timestamp
  created_at    timestamp [default: `now()`, not null]
  updated_at    timestamp [default: `now()`, not null]

  indexes {
    reviewer_id       [name: 'idx_rev_reviewer']
    reviewed_user_id  [name: 'idx_rev_reviewed_user']
    property_id       [name: 'idx_rev_property']
    deal_id           [name: 'idx_rev_deal']
    rating            [name: 'idx_rev_rating']
    is_visible        [name: 'idx_rev_visible']
    created_at        [name: 'idx_rev_created']
    (property_id, rating) [name: 'idx_rev_prop_rating']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 17. PROPERTY_VIEWS — سجل مشاهدات العقارات (Analytics)
// ──────────────────────────────────────────────────────────────────────────
Table property_views {
  id          bigint    [pk, increment]
  property_id bigint    [not null, ref: > properties.id]
  user_id     bigint    [ref: > users.id, note: 'NULL للزوار غير المسجلين']
  ip_address  varchar(45)
  user_agent  varchar(500)
  referrer    varchar(500)
  viewed_at   timestamp [default: `now()`, not null]

  indexes {
    property_id [name: 'idx_pview_property']
    user_id     [name: 'idx_pview_user']
    viewed_at   [name: 'idx_pview_time']
    (property_id, viewed_at) [name: 'idx_pview_prop_time']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 18. AUDIT_LOGS — سجل التدقيق
// ──────────────────────────────────────────────────────────────────────────
Table audit_logs {
  id          bigint    [pk, increment]
  table_name  varchar(50) [not null]
  record_id   bigint    [not null]
  action      enum('INSERT', 'UPDATE', 'DELETE') [not null]
  old_data    json
  new_data    json
  changed_fields text   [note: 'قائمة الحقول المتغيرة مفصولة بفاصلة']
  user_id     bigint    [ref: > users.id]
  ip_address  varchar(45)
  created_at  timestamp [default: `now()`, not null]

  indexes {
    table_name  [name: 'idx_audit_table']
    record_id   [name: 'idx_audit_record']
    action      [name: 'idx_audit_action']
    user_id     [name: 'idx_audit_user']
    created_at  [name: 'idx_audit_created']
    (table_name, record_id) [name: 'idx_audit_table_record']
    (table_name, action, created_at) [name: 'idx_audit_table_action_time']
  }
}

// ──────────────────────────────────────────────────────────────────────────
// 19. SYSTEM_SETTINGS — إعدادات النظام (Key-Value)
// ──────────────────────────────────────────────────────────────────────────
Table system_settings {
  id          bigint    [pk, increment]
  key         varchar(100) [unique, not null]
  value       text      [not null]
  data_type   enum('string', 'number', 'boolean', 'json') [default: 'string']
  description varchar(255)
  updated_by  bigint    [ref: > users.id]
  created_at  timestamp [default: `now()`, not null]
  updated_at  timestamp [default: `now()`, not null]

  indexes {
    key [unique, name: 'uq_setting_key']
  }
}

// ══════════════════════════════════════════════════════════════════════════
// RELATIONSHIPS
// ══════════════════════════════════════════════════════════════════════════

// Users → Properties
Ref: users.id < properties.owner_id     [delete: cascade]
Ref: users.id < properties.agent_id     [delete: set null]

// Properties → Images
Ref: properties.id < property_images.property_id [delete: cascade]

// Properties → Features
Ref: properties.id < property_features.property_id [delete: cascade]

// Properties → Favorites
Ref: properties.id < favorites.property_id [delete: cascade]
Ref: users.id < favorites.user_id [delete: cascade]

// Properties → Views
Ref: properties.id < property_views.property_id [delete: cascade]

// Users → Saved Searches
Ref: users.id < saved_searches.user_id [delete: cascade]

// Users → Requests
Ref: users.id < requests.user_id [delete: cascade]
Ref: properties.id < requests.property_id [delete: set null]
Ref: users.id < requests.assigned_agent_id [delete: set null]

// Deals → Users & Properties
Ref: properties.id < deals.property_id
Ref: users.id < deals.buyer_id
Ref: users.id < deals.seller_id
Ref: users.id < deals.agent_id     [delete: set null]
Ref: requests.id < deals.request_id [delete: set null]

// Payments
Ref: deals.id < payments.deal_id
Ref: users.id < payments.payer_id
Ref: users.id < payments.payee_id

// Discounts
Ref: users.id < discounts.created_by
Ref: properties.id < discounts.property_id [delete: set null]

// Conversations & Messages
Ref: properties.id < conversations.property_id [delete: set null]
Ref: users.id < conversations.participant_1
Ref: users.id < conversations.participant_2
Ref: conversations.id < messages.conversation_id [delete: cascade]
Ref: users.id < messages.sender_id

// Notifications
Ref: users.id < notifications.user_id [delete: cascade]

// Reviews
Ref: users.id < reviews.reviewer_id
Ref: users.id < reviews.reviewed_user_id
Ref: properties.id < reviews.property_id [delete: set null]
Ref: deals.id < reviews.deal_id [delete: set null]

// User Devices & Tokens
Ref: users.id < user_devices.user_id [delete: cascade]
Ref: users.id < refresh_tokens.user_id [delete: cascade]
Ref: user_devices.id < refresh_tokens.device_id [delete: set null]

// Audit Logs
Ref: users.id < audit_logs.user_id [delete: set null]

// System Settings
Ref: users.id < system_settings.updated_by [delete: set null]

