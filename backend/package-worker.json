{
  "name": "dealak-backend-worker",
  "version": "1.0.0",
  "description": "DEALAK Backend API for Cloudflare Workers",
  "main": "worker.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "d1:create": "wrangler d1 create dealak-db",
    "d1:migrate": "wrangler d1 execute dealak-db --file=./database/schema.sql",
    "d1:seed": "wrangler d1 execute dealak-db --file=./database/seed.sql"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "wrangler": "^3.50.0",
    "typescript": "^5.4.0"
  }
}
